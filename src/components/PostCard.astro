---
import type { CollectionEntry } from 'astro:content';
import { formatShort, isoDate } from '../utils/format-date';

type HeadingLevel = 'h2' | 'h3';

interface Props {
  post: CollectionEntry<'writing'>;
  headingLevel?: HeadingLevel;
}

const { post, headingLevel = 'h2' } = Astro.props;
const Heading = headingLevel;
---

<li class="post">
  <time datetime={isoDate(post.data.pubDate)}>{formatShort(post.data.pubDate)}</time>
  <div class="body">
    <Heading><a href={`/writing/${post.id}/`}>{post.data.title}</a></Heading>
    <p>{post.data.description}</p>
  </div>
</li>

<style>
  li.post {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-6);
    align-items: baseline;
  }

  @media (max-width: 640px) {
    li.post {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  time {
    font-size: var(--text-xs);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    padding-top: 6px;
  }

  .body :global(h2),
  .body :global(h3) {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.012em;
    margin-bottom: var(--space-2);
  }

  .body :global(h2 a),
  .body :global(h3 a) {
    color: var(--fg);
  }

  .body :global(h2 a:hover),
  .body :global(h3 a:hover) {
    color: var(--accent);
  }

  .body p {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.55;
    max-width: 540px;
  }
</style>
