---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatShort, isoDate } from '../../utils/format-date';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Writing — bellsoftware" description="Essays and notes." active="writing">
  <section class="archive">
    <header>
      <h1>Writing</h1>
    </header>
    <ul class="posts">
      {posts.map((post) => (
        <li class="post">
          <time datetime={isoDate(post.data.pubDate)}>{formatShort(post.data.pubDate)}</time>
          <div class="body">
            <h2><a href={`/writing/${post.id}/`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  section.archive {
    padding: var(--space-16) 0 var(--space-24);
    max-width: var(--content-max);
  }

  section.archive header {
    margin-bottom: var(--space-16);
  }

  section.archive h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.022em;
    line-height: 1.15;
  }

  ul.posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  li.post {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-6);
    align-items: baseline;
  }

  @media (max-width: 640px) {
    li.post {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    section.archive h1 {
      font-size: var(--text-2xl);
    }
  }

  li.post time {
    font-size: var(--text-xs);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    padding-top: 6px;
  }

  li.post .body h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.012em;
    margin-bottom: var(--space-2);
  }

  li.post .body h2 a {
    color: var(--fg);
  }

  li.post .body h2 a:hover {
    color: var(--accent);
  }

  li.post .body p {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.55;
    max-width: 540px;
  }
</style>
