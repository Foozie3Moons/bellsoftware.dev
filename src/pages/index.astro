---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { formatShort, isoDate } from '../utils/format-date';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout
  title="bellsoftware"
  description="Software engineer writing about platform reliability, frontend infrastructure, and the messy edges of agentic systems."
>
  <section class="hero">
    <h1>bellsoftware</h1>
    <p class="bio">
      Software engineer working on platform reliability, frontend infrastructure, and the messy edges of agentic systems. I write about <strong>systems thinking</strong>, observability, and what building with agents actually feels like.
    </p>
  </section>

  <section class="writing">
    <div class="label">Recent writing</div>
    <ul class="posts">
      {posts.map((post) => (
        <li class="post">
          <time datetime={isoDate(post.data.pubDate)}>{formatShort(post.data.pubDate)}</time>
          <div class="body">
            <h3><a href={`/writing/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </div>
        </li>
      ))}
    </ul>
    <a href="/writing" class="archive-link">All writing&nbsp;</a>
  </section>
</Layout>

<style>
  section.hero {
    padding: var(--space-24) 0 var(--space-16);
    max-width: var(--content-max);
  }

  section.hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.022em;
    margin-bottom: var(--space-6);
  }

  section.hero p.bio {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--muted);
    max-width: 640px;
  }

  section.hero p.bio strong {
    color: var(--fg);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    section.hero {
      padding: var(--space-16) 0 var(--space-12);
    }
    section.hero h1 {
      font-size: var(--text-3xl);
    }
    section.hero p.bio {
      font-size: var(--text-base);
    }
  }

  section.writing {
    padding: var(--space-12) 0 var(--space-24);
    border-top: 1px solid var(--border);
    max-width: var(--content-max);
  }

  section.writing > .label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: var(--space-12);
  }

  ul.posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  li.post {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-6);
    align-items: baseline;
  }

  @media (max-width: 640px) {
    li.post {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  li.post time {
    font-size: var(--text-xs);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    padding-top: 6px;
  }

  li.post .body h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.012em;
    margin-bottom: var(--space-2);
  }

  li.post .body h3 a {
    color: var(--fg);
  }

  li.post .body h3 a:hover {
    color: var(--accent);
  }

  li.post .body p {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.55;
    max-width: 540px;
  }

  .archive-link {
    margin-top: var(--space-12);
    font-size: var(--text-base);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .archive-link::after {
    content: '→';
    transition: transform 160ms ease;
  }

  .archive-link:hover::after {
    transform: translateX(3px);
  }
</style>
