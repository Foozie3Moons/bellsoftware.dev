---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostList from '../components/PostList.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout
  title="Matthew Bell"
  description="Software engineer writing about platform reliability, frontend infrastructure, and the messy edges of agentic systems."
>
  <section class="hero">
    <h1>Matthew Bell</h1>
    <p class="bio">
      Software engineer working on platform reliability, frontend infrastructure, and the messy edges of agentic systems. I write about <strong>systems thinking</strong>, observability, and what building with agents actually feels like.
    </p>
  </section>

  <section class="writing">
    <div class="label">Recent writing</div>
    <PostList posts={posts} headingLevel="h3" />
    <a href="/writing" class="archive-link">All writing&nbsp;</a>
  </section>
</Layout>

<style>
  section.hero {
    padding: var(--space-24) 0 var(--space-16);
    max-width: var(--content-max);
  }

  section.hero h1 {
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.022em;
    margin-bottom: var(--space-6);
  }

  section.hero p.bio {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--muted);
    max-width: 640px;
  }

  section.hero p.bio strong {
    color: var(--fg);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    section.hero {
      padding: var(--space-16) 0 var(--space-12);
    }
    section.hero h1 {
      font-size: var(--text-3xl);
    }
    section.hero p.bio {
      font-size: var(--text-base);
    }
  }

  section.writing {
    padding: var(--space-12) 0 var(--space-24);
    border-top: 1px solid var(--border);
    max-width: var(--content-max);
  }

  section.writing > .label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: var(--space-12);
  }

  .archive-link {
    margin-top: var(--space-12);
    font-size: var(--text-base);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .archive-link::after {
    content: '→';
    transition: transform 160ms ease;
  }

  .archive-link:hover::after {
    transform: translateX(3px);
  }
</style>
