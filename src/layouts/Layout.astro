---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: 'writing' | 'about' | null;
}

const { title, description, active = null } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="bellsoftware.dev" href="/rss.xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="page">
      <header class="site">
        <div class="row">
          <a href="/" class="wordmark">bellsoftware</a>
          <nav class="site-nav">
            <a href="/writing" class:list={[{ active: active === 'writing' }]}>Writing</a>
            <a href="/about" class:list={[{ active: active === 'about' }]}>About</a>
            <a href="/rss.xml">RSS</a>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site">
        <div class="row">
          <div>© {year} bellsoftware</div>
          <nav>
            <a href="/rss.xml">RSS</a>
            <a href="https://github.com">GitHub</a>
            <a href="mailto:hello@bellsoftware.dev">Email</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  header.site {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border);
  }

  header.site .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .wordmark {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  nav.site-nav {
    display: flex;
    gap: var(--space-6);
    font-size: var(--text-base);
  }

  nav.site-nav a {
    color: var(--muted);
  }

  nav.site-nav a:hover,
  nav.site-nav a.active {
    color: var(--fg);
  }

  footer.site {
    padding: var(--space-12) 0 var(--space-16);
    border-top: 1px solid var(--border);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  footer.site .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  footer.site nav {
    display: flex;
    gap: var(--space-6);
  }

  footer.site a {
    color: var(--muted);
  }

  footer.site a:hover {
    color: var(--fg);
  }
</style>
